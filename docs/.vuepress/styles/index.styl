

.avatar
  width 180px
  height 220px
  object-fit cover
  border-radius 8px
  box-shadow 0 4px 14px rgba(0, 0, 0, 0.12)

.hero-text h1
  margin-top 0
  margin-bottom 10px
  font-size 2.2rem

.subtitle
  color #555
  font-size 1.05rem
  margin-bottom 16px

.links a
  font-weight 600

h2
  margin-top 2.2rem
  border-bottom 1px solid #eaecef
  padding-bottom .35rem

h3
  margin-top 1.5rem

p, li
  color #2c3e50

a
  color #165dff

a:hover
  text-decoration underline

@media (max-width: 768px)
  .hero-profile
    flex-direction column
    align-items center
    text-align left

  .avatar
    width 160px
    height 200px


html, body
  font-family -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif
  color #1f2937
  line-height 1.7
  background #fff

.theme-default-content
  max-width 1100px !important
  font-size 16px
  padding-top 1.5rem

.intro-section
  display grid
  grid-template-columns 360px 1fr
  gap 44px
  align-items start
  margin 24px 0 12px 0

.intro-main h1
  margin 0 0 22px 0
  font-size 3.2rem
  line-height 1.05
  font-weight 700
  color #111827
  letter-spacing -0.02em

.intro-role
  margin 0 0 8px 0
  font-size 1.05rem
  color #4b5563

.intro-affiliation
  margin 0
  font-size 1.05rem
  color #4b5563

.intro-meta
  background #fafafa
  border 1px solid #e5e7eb
  border-radius 14px
  padding 22px 24px

.meta-row
  display grid
  grid-template-columns 110px 1fr
  gap 12px
  padding 10px 0
  border-bottom 1px solid #eceff3

.meta-row:last-child
  border-bottom none

.meta-label
  font-weight 600
  color #374151

.meta-value
  color #1f2937
  word-break break-word

.meta-value a
  color #2563eb
  text-decoration none

.meta-value a:hover
  text-decoration underline

.intro-divider
  margin 24px 0 8px 0
  border-bottom 1px solid #e5e7eb

h2
  margin-top 2rem
  border-bottom 1px solid #e5e7eb
  padding-bottom .35rem

h3
  margin-top 1.4rem

p, li
  color #334155

a
  color #2563eb

a:hover
  text-decoration underline

@media (max-width: 960px)
  .intro-section
    grid-template-columns 1fr
    gap 22px

  .intro-main h1
    font-size 2.5rem

  .intro-meta
    padding 18px 18px

  .meta-row
    grid-template-columns 90px 1fr

@media (max-width: 640px)
  .theme-default-content
    padding-top 1rem

  .intro-main h1
    font-size 2.1rem

  .meta-row
    grid-template-columns 1fr
    gap 4px

  .meta-label
    margin-bottom 2px


